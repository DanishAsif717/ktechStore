@{
	Layout = "~/Views/Shared/_ContentNavbarLayout.cshtml";
	var module = ViewBag.Module as ktechStore.Core.Entities.ModuleDefinition;
	var relationData = ViewBag.RelationData as Dictionary<string, List<Dictionary<string, object>>>;
}

<div class="container-xxl flex-grow-1 container-p-y">
	<h4 class="fw-bold mb-4">Add New — @module.ModuleName</h4>
    
	<div class="card p-4">
		<div class="col-md-6">
			<form method="post">
				@foreach (var field in module.Fields.OrderBy(f => f.DisplayOrder))
				{
					<div class="mb-3">
						<label class="form-label">@field.FieldName</label>
                        
						@if (field.FieldType == "Boolean")
						{
							<select name="@field.FieldName" class="form-select" @(field.IsRequired ? "required" : "")>
								<option value="true">Yes</option>
								<option value="false">No</option>
							</select>
						}
						else if (field.FieldType == "Relation")
						{
							<select name="@field.FieldName" class="form-select" @(field.IsRequired ? "required" : "")>
								<option value="">-- Select @field.FieldName --</option>
								
								@if (relationData != null && relationData.ContainsKey(field.FieldName))
								{
									foreach (var item in relationData[field.FieldName])
									{
										<option value="@item["Id"]">@item["Text"]</option>
									}
								}
							</select>
						}
						else if (field.FieldType == "TextArea")
						{
							<textarea name="@field.FieldName" class="form-control" rows="3" @(field.IsRequired ? "required" : "")></textarea>
						}
						else if (field.FieldType == "Date")
						{
							<input type="date" name="@field.FieldName" class="form-control" @(field.IsRequired ? "required" : "") />
						}
						else if (field.FieldType == "Number")
						{
							<input type="number" name="@field.FieldName" class="form-control" @(field.IsRequired ? "required" : "") />
						}
						else if (field.FieldType == "Email")
						{
							<input type="email" name="@field.FieldName" class="form-control" @(field.IsRequired ? "required" : "") />
						}
						else
						{
							<input type="text" name="@field.FieldName" class="form-control" @(field.IsRequired ? "required" : "") />
						}
					</div>
				}
                
				<button type="submit" class="btn btn-primary">Save</button>
				<a href="/admin/ModuleBuilder/Records/@module.Id" class="btn btn-secondary">Cancel</a>
			</form>
		</div>
	</div>
</div>
