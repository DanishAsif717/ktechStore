
@inject ktechStore.Core.Interfaces.IModuleService ModuleService
@{
	TempData.Keep();
	string? currentPage = ViewContext.HttpContext.Request.Path;
	var modules = await ModuleService.GetAllAsync();
}
<!-- Menu -->
@* ! Do this simple *@
<aside id="layout-menu" class="layout-menu menu-vertical menu bg-menu-theme">

  @* ! Hide app brand if navbar-full *@
  <div class='app-brand demo @((@ViewData["navbarFull"] != null && Convert.ToBoolean(@ViewData["navbarFull"])) ? "d-xl-none" : "")'>
    <a asp-controller="Dashboards" asp-action="Index" class="app-brand-link">
      <span class="app-brand-logo demo">
        @await Html.PartialAsync("../_Partials/_Macros")
      </span>
      <span class="app-brand-text demo menu-text fw-bold ms-2">@TempData.Peek("appName")</span>
    </a>

    <a href="javascript:void(0);" class="layout-menu-toggle menu-link text-large ms-auto">
      <i class="icon-base bx bx-chevron-left d-block d-xl-none align-middle"></i>
    </a>
  </div>

  <div class="menu-divider mt-0"></div>

  <div class="menu-inner-shadow"></div>

  @* ! Full version menu-items *@
  <ul class="menu-inner py-1">
    <!-- Dashboards -->
    <li class='menu-item@(currentPage.EndsWith("/") || currentPage.StartsWith("/Dashboards/") ? " active open" : "")'>
      <a href="javascript:void(0);" class="menu-link menu-toggle">
        <i class="menu-icon icon-base bx bx-home-smile"></i>
        <div class="text-truncate" data-i18n="Dashboards">Dashboards</div>
        <span class="badge rounded-pill bg-danger ms-auto">5</span>
      </a>
      <ul class="menu-sub">
        <li class='menu-item@(currentPage == "/" ? " active" : "")'>
          <a asp-controller="Dashboards" asp-action="Index" class="menu-link">
            <div class="text-truncate">Analytics</div>
          </a>
        </li>
		<li class='menu-item@(currentPage == "/" ? " active" : "")'>
			<a asp-controller="Categories" asp-action="Index" class="menu-link">
				<div class="text-truncate">Category For Danish</div>
			</a>
		</li>
		<li class='menu-item@(currentPage == "/" ? " active" : "")'>
			<a asp-controller="Products" asp-action="Index" class="menu-link">
				<div class="text-truncate">Products</div>
			</a>
		</li>
				
        
      </ul>
    </li>

	<!-- Dynamics -->
	<li class="menu-item @(currentPage.Contains("/ModuleBuilder") ? "active open" : "")">
		<a href="javascript:void(0);" class="menu-link menu-toggle">
			<i class="menu-icon icon-base bx bx-dock-top"></i>
			<div class="text-truncate">Module Builders</div>
		</a>
	
		<ul class="menu-sub">
			<li class="menu-item @(currentPage.EndsWith("/ModuleBuilder") || currentPage.EndsWith("/ModuleBuilder/Index") ? "active" : "")">
				<a asp-controller="ModuleBuilder" asp-action="Index" class="menu-link">
					<div class="text-truncate">Manage Modules</div>
				</a>
			</li>
		
			<li class="menu-item @(currentPage.Contains("/ModuleBuilder/Create") ? "active" : "")">
				<a asp-controller="ModuleBuilder" asp-action="Create" class="menu-link">
					<div class="text-truncate">Add Modules</div>
				</a>
			</li>

			@if (modules != null && modules.Any())
			{
				<li class="menu-header small text-uppercase mt-2">
					<span class="menu-header-text" style="font-size: 10px; padding: 0 20px; opacity: 0.6;">Dynamic Tables</span>
				</li>

				@foreach (var m in modules)
				{
					<li class="menu-item @(currentPage.Contains("/ModuleBuilder/Records/" + m.Id) ? "active" : "")">
						<a href="/admin/ModuleBuilder/Records/@m.Id" class="menu-link">
							<i class="menu-icon icon-base bx bx-data" style="font-size: 14px;"></i>
							<div class="text-truncate">@m.ModuleName</div>
						</a>
					</li>
				}
			}
		</ul>
	</li>

   
    <!-- Apps & Pages -->
    <li class="menu-header small text-uppercase">
      <span class="menu-header-text">Apps &amp; Pages</span>
    </li>

	
    <!-- Pages -->
    <li class='menu-item@(currentPage.StartsWith("/Pages/Account") ? " active open" : "")'>
      <a href="javascript:void(0);" class="menu-link menu-toggle">
        <i class="menu-icon icon-base bx bx-dock-top"></i>
        <div class="text-truncate">Account Settings</div>
      </a>
      <ul class="menu-sub">
        <li class='menu-item@(currentPage == "/Pages/AccountSettings" ? " active" : "")'>
          <a asp-controller="Pages" asp-action="AccountSettings" class="menu-link">
            <div class="text-truncate">Account</div>
          </a>
        </li>
        <li class='menu-item@(currentPage == "/Pages/AccountSettingsNotifications" ? " active" : "")'>
          <a asp-controller="Pages" asp-action="AccountSettingsNotifications" class="menu-link">
            <div class="text-truncate">Notifications</div>
          </a>
        </li>
        <li class='menu-item@(currentPage == "/Pages/AccountSettingsConnections" ? " active" : "")'>
          <a asp-controller="Pages" asp-action="AccountSettingsConnections" class="menu-link">
            <div class="text-truncate">Connections</div>
          </a>
        </li>
      </ul>
    </li>


    <li class='menu-item@(currentPage.StartsWith("/Auth") ? " active open" : "")'>
      <a href="javascript:void(0);" class="menu-link menu-toggle">
        <i class="menu-icon icon-base bx bx-lock-open-alt"></i>
        <div class="text-truncate">Authentications</div>
      </a>
      <ul class="menu-sub">
        <li class='menu-item@(currentPage == "/Auth/LoginBasic" ? " active" : "")'>
          <a asp-controller="Auth" asp-action="LoginBasic" class="menu-link" target="_blank">
            <div class="text-truncate">Login</div>
          </a>
        </li>
        <li class='menu-item@(currentPage == "/Auth/RegisterBasic" ? " active" : "")'>
          <a asp-controller="Auth" asp-action="RegisterBasic" class="menu-link" target="_blank">
            <div class="text-truncate">Register</div>
          </a>
        </li>
        <li class='menu-item@(currentPage == "/Auth/ForgotPasswordBasic" ? " active" : "")'>
          <a asp-controller="Auth" asp-action="ForgotPasswordBasic" class="menu-link" target="_blank">
            <div class="text-truncate">Forgot Password</div>
          </a>
        </li>
      </ul>
    </li>
    <li class='menu-item@(currentPage.StartsWith("/Pages/Misc") ? " active open" : "")'>
        <a href="javascript:void(0);" class="menu-link menu-toggle">
        <i class="menu-icon icon-base bx bx-cube-alt"></i>
        <div class="text-truncate">Misc</div>
      </a>
      <ul class="menu-sub">
        <li class='menu-item@(currentPage == "/Pages/MiscError" ? " active" : "")'>
          <a asp-controller="Pages" asp-action="MiscError" class="menu-link" target="_blank">
            <div class="text-truncate">Error</div>
          </a>
        </li>
        <li class='menu-item@(currentPage == "/Pages/MiscUnderMaintenance" ? " active" : "")'>
          <a asp-controller="Pages" asp-action="MiscUnderMaintenance" class="menu-link" target="_blank">
          <div class="text-truncate">Under Maintenance</div>
          </a>
        </li>
      </ul>
    </li>
    <!-- Components -->
    <li class="menu-header small text-uppercase"><span class="menu-header-text">Components</span></li>
    <!-- Cards -->
    <li class='menu-item@(currentPage == "/Cards/Basic" ? " active" : "")'>
      <a asp-controller="Cards" asp-action="Basic" class="menu-link">
        <i class="menu-icon icon-base bx bx-collection"></i>
        <div class="text-truncate" data-i18n="Cards">Cards</div>
      </a>
    </li>
    <!-- User interface -->
    <li class='menu-item@(currentPage.StartsWith("/Ui") ? " active open" : "")'>
      <a href="javascript:void(0)" class="menu-link menu-toggle">
        <i class="menu-icon icon-base bx bx-box"></i>
        <div class="text-truncate">User interface</div>
      </a>
      <ul class="menu-sub">
        <li class='menu-item@(currentPage == "/Ui/Accordion" ? " active" : "")'>
          <a asp-controller="Ui" asp-action="Accordion" class="menu-link">
            <div class="text-truncate">Accordion</div>
          </a>
        </li>
        <li class='menu-item@(currentPage == "/Ui/Alerts" ? " active" : "")'>
          <a asp-controller="Ui" asp-action="Alerts" class="menu-link">
            <div class="text-truncate">Alerts</div>
          </a>
        </li>
        <li class='menu-item@(currentPage == "/Ui/Badges" ? " active" : "")'>
          <a asp-controller="Ui" asp-action="Badges" class="menu-link">
