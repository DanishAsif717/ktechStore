        <i class="menu-icon icon-base bx bx-detail"></i>
        <div class="text-truncate">Form Layouts</div>
      </a>
      <ul class="menu-sub">
        <li class='menu-item@(currentPage == "/FormLayouts/Vertical" ? " active" : "")'>
          <a asp-controller="FormLayouts" asp-action="Vertical" class="menu-link">
            <div class="text-truncate">Vertical Form</div>
          </a>
        </li>
        <li class='menu-item@(currentPage == "/FormLayouts/Horizontal" ? " active" : "")'>
          <a asp-controller="FormLayouts" asp-action="Horizontal" class="menu-link">
            <div class="text-truncate">Horizontal Form</div>
          </a>
        </li>
      </ul>
    </li>
    <!-- Form Validation -->
    <li class='menu-item@(currentPage == "/FormValidation/Validation" ? " active" : "")'>
      <a href="https://demos.themeselection.com/sneat-aspnet-core-mvc-admin-template/html/vertical-menu-template/form-validation.html" target="_blank" class="menu-link">
        <i class="menu-icon icon-base bx bx-list-check"></i>
        <div class="text-truncate">Form Validation</div><div class="badge rounded-pill bg-label-primary text-uppercase fs-tiny ms-auto">Pro</div>
      </a>
    </li>
    <!-- Tables -->
    <li class='menu-item@(currentPage == "/Tables/Basic" ? " active" : "")'>
      <a asp-controller="Tables" asp-action="Basic" class="menu-link">
